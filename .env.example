# Copie este arquivo para .env e preencha os valores antes de iniciar o sistema.
# O arquivo .env nunca deve ser commitado no repositório.

# Chave secreta para assinar os tokens JWT. Gere com: openssl rand -hex 32
JWT_SECRET=

# Usuário administrador criado automaticamente na primeira execução
ADMIN_USER=admin

# Senha do administrador — obrigatório, mínimo 8 caracteres
ADMIN_PASSWORD=
