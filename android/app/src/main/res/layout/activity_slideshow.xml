<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ImageView
        android:id="@+id/slide_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop" />

    <FrameLayout
        android:id="@+id/overlay_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <View
            android:id="@+id/overlay_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#80000000"
            android:clickable="true"
            android:focusable="false" />

        <LinearLayout
            android:id="@+id/buttons_row"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@null"
                android:focusable="false"
                android:src="@drawable/ic_prev"
                android:contentDescription="Anterior" />

            <ImageButton
                android:id="@+id/btn_pause"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@null"
                android:focusable="false"
                android:src="@drawable/ic_pause"
                android:contentDescription="Pausar" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:background="@null"
                android:focusable="false"
                android:src="@drawable/ic_next"
                android:contentDescription="Próximo" />

        </LinearLayout>

    </FrameLayout>

    <ImageView
        android:id="@+id/pause_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:src="@drawable/ic_pause"
        android:alpha="0.6"
        android:visibility="gone"
        android:contentDescription="Pausado" />

</FrameLayout>
